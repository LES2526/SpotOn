# Base environment for local development. Tests override via .env.test (see Makefile postman-ci).

# Local Postgres (docker compose on port 5432)
DATABASE_URL="postgresql://admin:admin@localhost:5432/spot_on_db"

# NextAuth base URL (used by callbacks and magic-link emails)
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="q/ap6iLt2BciK65X1IyJNxArHC5JdTx2KaR35lM0mtY="

# Restrict sign-in to this domain; set ALLOW_ANY_EMAIL_IN_DEV=true to bypass during dev
ALLOWED_EMAIL_DOMAIN="ualg.pt"
ALLOW_ANY_EMAIL_IN_DEV="true"

# Shared HMAC key for rotating QR tokens (must match between server and QR tablet)
QR_SECRET="N3LxlmMBZNVOmMuAbOgGHkO++icNQ2Md/ATohwaEQLM="

# Library closing time in UTC (HH:MM) — used to cap session expectedEndTime
LIBRARY_CLOSING_TIME="19:30"

# Set to "true" to skip library opening-hours enforcement during development
BYPASS_HOURS_CHECK="true"

# Resend API key for transactional email (magic-link, notifications)
RESEND_API_KEY="re_QpfWX4YS_6ZB67psJRkZFXVVc3xRBfKjw"

# "From" address shown in outgoing emails (must be a verified domain in Resend)
EMAIL_FROM="Spot-On UAlg <noreply@spoton-ualg.site>"
