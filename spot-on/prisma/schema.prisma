// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// ============================================
// NextAuth.js Models
// ============================================

/// Spot-On system user.
/// Only @ualg.pt emails are accepted (validated in backend).
model User {
    id            String    @id @default(cuid()) @db.VarChar(30)
    studentId     String?   @unique @db.VarChar(20)
    department    String?   @db.VarChar(255)
    name          String?   @db.VarChar(255)
    email         String    @unique @db.VarChar(255)
    emailVerified DateTime?
    image         String?   @db.VarChar(255)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    accounts Account[]
    sessions Session[]

    hostedStudySessions StudySession[]       @relation("SessionHost")
    participations      UserOnStudySession[]

    @@map("users")
}

/// NextAuth authentication providers.
/// Supports multiple providers per user (email, OAuth, etc).
model Account {
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([provider, providerAccountId])
    @@map("accounts")
}

/// Active login sessions.
model Session {
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("sessions")
}

/// Magic link tokens for passwordless authentication.
/// Expire after 5 minutes.
model VerificationToken {
    identifier String /// User email
    token      String   @unique
    expires    DateTime

    @@id([identifier, token])
    @@map("verification_tokens")
}

// ============================================
// Spot-On Domain Models
// ============================================

enum SessionStatus {
    ACTIVE
    COMPLETED
    OVERDUE
}

enum InvitationStatus {
    PENDING
    ACCEPTED
    REJECTED
}

/// Study space (room, library, etc).
model Space {
    id             String   @id @default(cuid()) @db.VarChar(30)
    name           String   @db.VarChar(255)
    location       String   @db.VarChar(255)
    capacity       Int
    currentQrToken String?  @unique @db.VarChar(255) /// Current QR token for check-in
    description    String?  @db.VarChar(255)
    hasPowerOutlet Boolean  @default(false)
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    sessions StudySession[]

    @@map("spaces")
}

/// Study session in a space.
model StudySession {
    id      String @id @default(cuid()) @db.VarChar(30)
    spaceId String @db.VarChar(30)
    hostId  String @db.VarChar(30)

    startTime       DateTime  @default(now())
    expectedEndTime DateTime
    actualEndTime   DateTime?

    status SessionStatus @default(ACTIVE)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    space        Space                @relation(fields: [spaceId], references: [id])
    host         User                 @relation("SessionHost", fields: [hostId], references: [id])
    participants UserOnStudySession[]

    @@map("study_sessions")
}

/// User participation in study session (pivot table).
model UserOnStudySession {
    userId    String @db.VarChar(30)
    sessionId String @db.VarChar(30)

    isHost   Boolean          @default(false)
    status   InvitationStatus @default(PENDING)
    joinedAt DateTime         @default(now())

    user    User         @relation(fields: [userId], references: [id])
    session StudySession @relation(fields: [sessionId], references: [id])

    @@id([userId, sessionId])
    @@map("users_study_sessions")
}
