generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  OVERDUE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id        String   @id @default(cuid()) @db.VarChar(30)
  email     String   @unique @db.VarChar(255)
  name      String   @db.VarChar(255)
  password  String   @db.VarChar(255)
  image     String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  hostedSessions StudySession[]       @relation("SessionHost") // sessões que criou
  participations UserOnStudySession[] // sessões onde participa (incluindo as que criou)

  @@map("users")
}

model Space {
  id             String   @id @default(cuid()) @db.VarChar(30)
  name           String   @db.VarChar(255)
  location       String   @db.VarChar(255)
  capacity       Int
  currentQrToken String?  @unique @db.VarChar(255)
  description    String?  @db.VarChar(255)
  hasPowerOutlet Boolean  @default(false)
  // isOccupied     Boolean  @default(false) 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions StudySession[]

  @@map("spaces")
}

model StudySession {
  id      String @id @default(cuid()) @db.VarChar(30)
  spaceId String @db.VarChar(30)
  hostId  String @db.VarChar(30)

  startTime       DateTime  @default(now())
  expectedEndTime DateTime
  actualEndTime   DateTime?

  status SessionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space        Space           @relation(fields: [spaceId], references: [id])
  host         User            @relation("SessionHost", fields: [hostId], references: [id])
  participants UserOnStudySession[]

  @@map("study_sessions")
}

model UserOnStudySession {
  userId    String @db.VarChar(30)
  sessionId String @db.VarChar(30)

  isHost   Boolean          @default(false)
  status   InvitationStatus @default(PENDING)
  joinedAt DateTime         @default(now())

  user    User    @relation(fields: [userId], references: [id])
  session StudySession @relation(fields: [sessionId], references: [id])

  @@id([userId, sessionId])
  @@map("UserOnSession")
}
