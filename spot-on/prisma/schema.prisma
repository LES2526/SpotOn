// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================
// NextAuth.js Models
// ============================================

/// Spot-On system user.
/// Only @ualg.pt emails are accepted (validated in backend).
model User {
    id            String    @id @default(cuid()) @db.VarChar(30)
    studentId     String?   @unique @db.VarChar(20)
    email         String    @unique @db.VarChar(255)
    emailVerified DateTime?
    image         String?   @db.VarChar(255)

    points Int @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now()) @updatedAt

    accounts Account[]
    sessions Session[]

    hostedStudySessions StudySession[]       @relation("SessionHost")
    participations      UserOnStudySession[]
    reports             Report[]
}

/// NextAuth authentication providers.
/// Supports multiple providers per user (email, OAuth, etc).
model Account {
    userId            String  @db.VarChar(30)
    type              String  @db.VarChar(50)
    provider          String  @db.VarChar(50)
    providerAccountId String  @db.VarChar(255)
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String? @db.VarChar(50)
    scope             String? @db.Text /// Space-separated permissions/scopes granted by the provider
    id_token          String? @db.Text
    session_state     String? @db.VarChar(255)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([provider, providerAccountId])
}

/// Active login sessions.
model Session {
    id           String   @id @default(cuid()) @db.VarChar(30)
    sessionToken String   @unique @db.VarChar(255)
    userId       String   @db.VarChar(30)
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Magic link tokens for passwordless authentication.
/// Expire after 5 minutes.
model VerificationToken {
    identifier String   @db.VarChar(255)
    token      String   @unique @db.VarChar(255)
    expires    DateTime

    @@id([identifier, token])
}

// ============================================
// Spot-On Domain Models
// ============================================

// --------------------------------------------
// Enums
// - SessionStatus, InvitationStatus, SpaceType,
//   ReportStatus
// --------------------------------------------

enum SessionStatus {
    ACTIVE
    COMPLETED
    EXPIRED
}

enum InvitationStatus {
    PENDING
    ACCEPTED
    REJECTED
}

enum SpaceType {
    INDIVIDUAL_DESK
    GROUP_ROOM
}

enum SpaceShape {
    CIRCULAR_DESK
    RETANGULAR_DESK
}

enum ReportStatus {
    OPEN
    RESOLVED
    EXPIRED
}

/// Floor plan canvas. Spaces are positioned relative to this container.
// --------------------------------------------
// Floor plan & Spaces
// --------------------------------------------
model FloorPlan {
    id          String @id @default(cuid()) @db.VarChar(30)
    name        String @db.VarChar(255)
    floor       Int    @unique @default(0)
    imageUrl    String @db.VarChar(255) /// URL or path to the floor plan image
    imageWidth  Int
    imageHeight Int

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now()) @updatedAt

    spaces Space[]
}

/// Study space
// --------------------------------------------
// Space model
// --------------------------------------------
model Space {
    id             String    @id @default(cuid()) @db.VarChar(30)
    floorPlanId    String    @db.VarChar(30)
    name           String    @db.VarChar(255)
    points         String /// SVG polygon points: "x1,y1 x2,y2 x3,y3 x4,y4" (clockwise from top-left)
    capacity       Int
    currentQrToken String    @unique @db.VarChar(255) /// Rotates periodically; displayed on the space's tablet
    description    String?   @db.VarChar(255)
    hasPowerOutlet Boolean   @default(false)
    type           SpaceType @default(INDIVIDUAL_DESK)
    shape          SpaceShape?

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now()) @updatedAt

    floorPlan FloorPlan      @relation(fields: [floorPlanId], references: [id])
    sessions  StudySession[]
}

/// Study session in a space.
// --------------------------------------------
// Sessions
// --------------------------------------------
model StudySession {
    id      String @id @default(cuid()) @db.VarChar(30)
    spaceId String @db.VarChar(30)
    hostId  String @db.VarChar(30)

    startTime       DateTime  @default(now())
    expectedEndTime DateTime
    actualEndTime   DateTime?

    status SessionStatus @default(ACTIVE)

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now()) @updatedAt

    space Space @relation(fields: [spaceId], references: [id])
    host  User  @relation("SessionHost", fields: [hostId], references: [id])

    participants UserOnStudySession[]
    reports      Report[]
}

/// User participation in study session (pivot table).
// --------------------------------------------
// Participation (pivot) models
// --------------------------------------------
model UserOnStudySession {
    userId    String @db.VarChar(30)
    sessionId String @db.VarChar(30)

    status   InvitationStatus @default(PENDING)
    joinedAt DateTime         @default(now())

    user    User         @relation(fields: [userId], references: [id])
    session StudySession @relation(fields: [sessionId], references: [id])

    @@id([userId, sessionId])
}

/// User report about a study session.
// --------------------------------------------
// Reports
// --------------------------------------------
model Report {
    id         String       @id @default(cuid()) @db.VarChar(30)
    reporterId String       @db.VarChar(30)
    sessionId  String       @db.VarChar(30)
    reason     String       @db.VarChar(255)
    status     ReportStatus @default(OPEN)

    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @default(now()) @updatedAt
    timeToConfirm DateTime  @default(dbgenerated("now() + interval '10 minutes'")) /// 10 minutes to confirm the report
    confirmedAt   DateTime?

    reporter User         @relation(fields: [reporterId], references: [id])
    session  StudySession @relation(fields: [sessionId], references: [id])
}
