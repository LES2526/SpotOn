# Overrides only. Base values are loaded from .env first (see Makefile postman-ci).

# Test DB on its own port so dev DB isn't touched
DATABASE_URL="postgresql://admin:admin@localhost:5434/spot_on_test_db"

# Server runs on a separate port during tests
NEXTAUTH_URL="http://localhost:3001"

# Non-secret values just for CI / Postman runs
NEXTAUTH_SECRET="ci-nextauth-secret"
QR_SECRET="ci-qr-secret"

# Keep strict email domain validation in tests
ALLOW_ANY_EMAIL_IN_DEV=false

# Push the library closing time to end-of-day so tests that create sessions
# at "now + 1h" never get clamped by the after-hours check, regardless of
# when the suite is executed locally.
LIBRARY_CLOSING_TIME="23:59"

# Dummy SMTP (mailcatcher / MailHog on 1025); avoids real emails being sent
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT="1025"
EMAIL_SERVER_USER="test@test.com"
EMAIL_SERVER_PASSWORD="test"
EMAIL_FROM="Spot-On Test <test@test.com>"
